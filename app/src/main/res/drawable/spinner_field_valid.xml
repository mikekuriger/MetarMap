<?xml version="1.0" encoding="utf-8"?>
<!-- Green-bordered variant of spinner_field, applied programmatically when
     the spinner's current value passes validation. Companion to
     spinner_field.xml (red, "invalid/needs-attention"). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="@android:color/black" />
    <stroke android:width="2dp" android:color="#66BB6A" />
    <corners android:radius="4dp" />
</shape>
