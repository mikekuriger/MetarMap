<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FlightPlanActivity"
    android:background="@android:color/darker_gray">

    <!-- ✅ Top Row: Button & Text Input Box -->
    <Button
        android:id="@+id/searchButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Search"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="0dp" />

    <EditText
        android:id="@+id/searchBox"
        android:hint="KBUR"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/searchButton"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="0dp" />

    <!-- ✅ Big Text Box on Left -->
    <TextView
        android:id="@+id/searchResults"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:hint=""
        android:textSize="18sp"
        android:gravity="top|start"
        android:padding="0dp"
        app:layout_constraintTop_toBottomOf="@id/searchBox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/clearFlightPlanButton"
        app:layout_constraintBottom_toBottomOf="@id/plotFlightPlanButton"
        android:layout_margin="2dp" />

    <!-- ✅ Button2 (Top Right) -->
    <Button
        android:id="@+id/clearFlightPlanButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Clear"
        app:layout_constraintTop_toBottomOf="@id/searchBox"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="0dp" />

    <!-- ✅ Button3 (Below Button2) -->
    <Button
        android:id="@+id/plotFlightPlanButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Save"
        app:layout_constraintTop_toBottomOf="@id/clearFlightPlanButton"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="0dp" />

    <!-- ✅ Empty Space Below Buttons -->
    <TextView
        android:id="@+id/flightPlanDisplay"
        android:text="Flight Plan: None"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/plotFlightPlanButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

