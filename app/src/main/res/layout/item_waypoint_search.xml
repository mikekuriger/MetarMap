<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Code is colored by type (green=airport, blue=navaid, yellow=fix) so we
         don't need a separate type chip and can give the full row width to the
         airport name + city. -->
    <TextView
        android:id="@+id/codeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="56dp"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        tools:text="KVNY"
        xmlns:tools="http://schemas.android.com/tools" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp">

        <TextView
            android:id="@+id/nameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#EEEEEE"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Van Nuys Airport"
            xmlns:tools="http://schemas.android.com/tools" />

        <TextView
            android:id="@+id/locationText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#999999"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Van Nuys, CA"
            xmlns:tools="http://schemas.android.com/tools" />
    </LinearLayout>

    <!-- Type chip removed — the colored code already conveys airport vs navaid vs fix.
         Frees up ~70dp of width for the airport name on narrow screens. -->
</LinearLayout>
