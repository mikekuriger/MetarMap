<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:background="@color/dark_gray">

    <TextView
        android:id="@+id/flightPlanText"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="8dp"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Flight Plan Editor"
        android:textColor="@android:color/white"
        android:textSize="20sp" />

<!--    <EditText-->
<!--        android:id="@+id/flightPlanEdit"-->
<!--        android:layout_width="match_parent"-->
<!--        android:background="@drawable/edit_text"-->
<!--        android:textColor="#FFFFFF"-->
<!--        android:textCursorDrawable="@null"-->
<!--        android:padding="10dp"-->
<!--        android:textColorHint="#AAAAAA"-->
<!--        android:inputType="textMultiLine"-->
<!--        android:maxLines="3"-->
<!--        android:layout_height="85dp"-->
<!--        android:hint="Enter flight plan"-->
<!--        app:layout_constraintTop_toBottomOf="@id/flightPlanText"-->
<!--        />-->

    <EditText
        android:id="@+id/flightPlanEdit"
        android:layout_width="match_parent"
        android:background="@drawable/edit_text"
        android:textColor="#FFFFFF"
        android:textCursorDrawable="@null"
        android:padding="10dp"
        android:textColorHint="#AAAAAA"
        android:inputType="textMultiLine"
        android:maxLines="3"
        android:layout_height="85dp"
        android:hint="Enter Waypoints"
        app:layout_constraintTop_toBottomOf="@id/flightPlanText"
        android:gravity="top|start"
        android:layout_marginTop="0dp"
        android:textSize="16sp" />

    <!-- Buttons stack, pinned to the right edge so the wide left column
         is free for the new search input + results list. -->
    <LinearLayout
        android:id="@+id/flightPlanButtonLayout"
        android:layout_width="140dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="4dp"
        app:layout_constraintTop_toBottomOf="@id/flightPlanEdit"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/reverseFlightPlanButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reverse" />

        <Button
            android:id="@+id/clearFlightPlanButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear" />

        <Button
            android:id="@+id/loadFlightPlanButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Load" />

        <Button
            android:id="@+id/saveFlightPlanButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save" />

        <Button
            android:id="@+id/deleteFlightPlanButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Delete" />

        <Button
            android:id="@+id/activateFlightPlanButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exit" />
    </LinearLayout>

    <!-- Search input — sits to the left of the button stack, below the plan editor. -->
    <EditText
        android:id="@+id/searchInput"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_margin="4dp"
        android:background="@drawable/edit_text"
        android:hint="Search airport, city, navaid, or fix"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:padding="10dp"
        android:singleLine="true"
        android:textColor="#FFFFFF"
        android:textColorHint="#AAAAAA"
        android:textCursorDrawable="@null"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/flightPlanButtonLayout"
        app:layout_constraintTop_toBottomOf="@id/flightPlanEdit" />

    <!-- Results list — fills the space below the search input down to the bottom of the screen. -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/searchResults"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="4dp"
        android:background="#202020"
        android:scrollbars="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/flightPlanButtonLayout"
        app:layout_constraintTop_toBottomOf="@id/searchInput"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

