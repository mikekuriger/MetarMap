<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:background="@color/dark_gray">

    <TextView
        android:id="@+id/flightPlanText"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="8dp"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Flight Plan Editor"
        android:textColor="@android:color/white"
        android:textSize="20sp" />

<!--    <EditText-->
<!--        android:id="@+id/flightPlanEdit"-->
<!--        android:layout_width="match_parent"-->
<!--        android:background="@drawable/edit_text"-->
<!--        android:textColor="#FFFFFF"-->
<!--        android:textCursorDrawable="@null"-->
<!--        android:padding="10dp"-->
<!--        android:textColorHint="#AAAAAA"-->
<!--        android:inputType="textMultiLine"-->
<!--        android:maxLines="3"-->
<!--        android:layout_height="85dp"-->
<!--        android:hint="Enter flight plan"-->
<!--        app:layout_constraintTop_toBottomOf="@id/flightPlanText"-->
<!--        />-->

    <!-- Aircraft / Profile / Cruise Altitude pickers. Horizontal row above
         the waypoints box so the user can pick context first, then enter
         the route. Each column gets equal weight; labels are tiny so all
         three fit on a phone in portrait. -->
    <LinearLayout
        android:id="@+id/aircraftPickerRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/flightPlanText">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aircraft"
                android:textColor="@android:color/white"
                android:textSize="10sp" />

            <Spinner
                android:id="@+id/aircraftSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/spinner_field" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="2dp"
            android:paddingEnd="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="@android:color/white"
                android:textSize="10sp" />

            <Spinner
                android:id="@+id/profileSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/spinner_field" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cruise Altitude"
                android:textColor="@android:color/white"
                android:textSize="10sp" />

            <Spinner
                android:id="@+id/cruiseAltitudeSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/spinner_field"
                android:popupBackground="@android:color/black" />
        </LinearLayout>

    </LinearLayout>

    <EditText
        android:id="@+id/flightPlanEdit"
        android:layout_width="match_parent"
        android:background="@drawable/edit_text"
        android:textColor="#FFFFFF"
        android:textCursorDrawable="@null"
        android:padding="10dp"
        android:textColorHint="#AAAAAA"
        android:inputType="textMultiLine"
        android:maxLines="3"
        android:layout_height="85dp"
        android:hint="Enter Waypoints"
        app:layout_constraintTop_toBottomOf="@id/aircraftPickerRow"
        android:gravity="top|start"
        android:layout_marginTop="0dp"
        android:textSize="16sp" />

    <!-- Buttons stack, pinned to the right edge so the wide left column
         is free for the new search input + results list. -->
    <LinearLayout
        android:id="@+id/flightPlanButtonLayout"
        android:layout_width="110dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="4dp"
        app:layout_constraintTop_toBottomOf="@id/flightPlanEdit"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/activateFlightPlanButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exit" />

        <Button
            android:id="@+id/reverseFlightPlanButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reverse" />

        <Button
            android:id="@+id/clearFlightPlanButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear" />

        <Button
            android:id="@+id/loadFlightPlanButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Load" />

        <Button
            android:id="@+id/saveFlightPlanButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save" />

        <Button
            android:id="@+id/deleteFlightPlanButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Delete" />

        <Button
            android:id="@+id/manageAircraftButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage Aircraft" />
    </LinearLayout>

    <!-- Search input — sits directly under the waypoints box, to the left
         of the button stack. -->
    <EditText
        android:id="@+id/searchInput"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_margin="4dp"
        android:background="@drawable/edit_text"
        android:hint="Search"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:padding="10dp"
        android:singleLine="true"
        android:textColor="#FFFFFF"
        android:textColorHint="#AAAAAA"
        android:textCursorDrawable="@null"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/flightPlanButtonLayout"
        app:layout_constraintTop_toBottomOf="@id/flightPlanEdit" />

    <!-- Live preview of the plan totals — distance / time / fuel computed from
         the current waypoints, aircraft profile, cruise altitude and forecast
         wind. Tappable: opens the full Nav Log breakdown for the same plan,
         which is just this strip's numbers expanded leg-by-leg. -->
    <TextView
        android:id="@+id/previewSummary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="6dp"
        android:gravity="center"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:background="#202020"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="2dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/flightPlanButtonLayout"
        app:layout_constraintTop_toBottomOf="@id/searchInput" />

    <!-- Results list — fills the space below the search input down to the bottom of the screen. -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/searchResults"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="4dp"
        android:background="#202020"
        android:scrollbars="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/flightPlanButtonLayout"
        app:layout_constraintTop_toBottomOf="@id/previewSummary"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

